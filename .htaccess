# ================================================================
#  IjaraGo — Apache .htaccess
#  404 redirect | Compression | Security | Cache Control
# ================================================================

# ===== 404 ERROR PAGE =====
ErrorDocument 404 /404.html
ErrorDocument 403 /404.html

# ===== HTTPS REDIRECT (production da yoqish) =====
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ===== GZIP COMPRESSION =====
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ===== BROWSER CACHE =====
<IfModule mod_expires.c>
    ExpiresActive On
    # HTML - 1 kun
    ExpiresByType text/html                  "access plus 1 day"
    # CSS, JS - 1 oy
    ExpiresByType text/css                   "access plus 1 month"
    ExpiresByType application/javascript     "access plus 1 month"
    ExpiresByType text/javascript            "access plus 1 month"
    # Rasmlar - 3 oy
    ExpiresByType image/png                  "access plus 3 months"
    ExpiresByType image/jpg                  "access plus 3 months"
    ExpiresByType image/jpeg                 "access plus 3 months"
    ExpiresByType image/gif                  "access plus 3 months"
    ExpiresByType image/webp                 "access plus 3 months"
    ExpiresByType image/svg+xml              "access plus 3 months"
    ExpiresByType image/x-icon               "access plus 1 year"
    # Shriftlar - 1 yil
    ExpiresByType font/woff                  "access plus 1 year"
    ExpiresByType font/woff2                 "access plus 1 year"
    ExpiresByType application/font-woff      "access plus 1 year"
    # JSON - Manifest
    ExpiresByType application/json           "access plus 1 week"
    ExpiresByType application/manifest+json  "access plus 1 week"
</IfModule>

# ===== SECURITY HEADERS =====
<IfModule mod_headers.c>
    # XSS himoya
    Header always set X-XSS-Protection "1; mode=block"
    # Clickjacking himoya
    Header always set X-Frame-Options "SAMEORIGIN"
    # MIME sniffing himoya
    Header always set X-Content-Type-Options "nosniff"
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Service Worker uchun ruxsat
    Header always set Service-Worker-Allowed "/"
    # Cache-Control for HTML
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "max-age=86400, must-revalidate"
    </FilesMatch>
    # Long cache for static assets
    <FilesMatch "\.(css|js|woff|woff2|png|jpg|jpeg|gif|webp|svg|ico)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
</IfModule>

# ===== KEEP ALIVE =====
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# ===== REMOVE SERVER SIGNATURE =====
ServerTokens Prod
ServerSignature Off

# ===== BLOCK ACCESS TO SENSITIVE FILES =====
<FilesMatch "(^\.htaccess|^\.htpasswd|^\.env|^\.git)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ===== CHARSET =====
AddDefaultCharset UTF-8
